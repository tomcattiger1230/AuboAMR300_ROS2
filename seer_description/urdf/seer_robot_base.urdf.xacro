<?xml version="1.0"?>
<robot name="seer_amb" xmlns:xacro="http://ros.org/wiki/xacro">

  <xacro:property name="base_mass" value="110.0" />
  <xacro:property name="wheel_mass" value="6.0" />

  <xacro:property name="wheel_radius" value="0.1" />
  <xacro:property name="wheel_length" value="0.05" />

  <xacro:property name="wheel_ygap" value="0.3" />
  <xacro:property name="wheel_xoff" value="0.0" />
  <xacro:property name="wheel_zoff" value="0.1" />

  <link name="base_footprint" />

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint" />
    <child link="base_link" />
    <origin xyz="0.0 0.0 ${wheel_radius - wheel_zoff}" rpy="0 0 0" />
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.26" rpy="0 0 ${pi}" />
      <geometry>
        <mesh filename="package://seer_description/meshes/robot_body.stl" scale="0.1 0.1 0.1" />
      </geometry>
      <material name="orange">
        <color rgba="0.922 0.57 0.82 1.0" />
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0.35" rpy="0 0 0" />
      <geometry>
        <box size="1.00 0.70 0.50" />
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0.15" rpy="0 0 0" />
      <mass value="${base_mass}" />
      <inertia ixx="3.11" ixy="0.0" ixz="0.0" iyy="6.68" iyz="0.0" izz="8.15" />
    </inertial>
  </link>

  <xacro:macro name="drive_wheel" params="prefix y_reflect filename">
    <link name="${prefix}_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://seer_description/meshes/${filename}" scale="0.1 0.1 0.1" />
        </geometry>
        <material name="black">
          <color rgba="0.1 0.1 0.1 1.0" />
        </material>
      </visual>

      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0" />
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_length}" />
        </geometry>
      </collision>

      <inertial>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0" />
        <mass value="${wheel_mass}" />
        <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01" />
      </inertial>
    </link>

    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link" />
      <child link="${prefix}_wheel_link" />
      <origin xyz="${wheel_xoff} ${y_reflect * wheel_ygap} ${wheel_zoff}" rpy="0 0 0" />
      <axis xyz="0 1 0" />
    </joint>
  </xacro:macro>
  <xacro:drive_wheel prefix="left" y_reflect="1" filename="left_wheel.stl" />
  <xacro:drive_wheel prefix="right" y_reflect="-1" filename="right_wheel.stl" />

  <xacro:macro name="lidar" params="prefix xy_reflect x_offset y_offset filename">
    <link name="${prefix}_lidar_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://seer_description/meshes/${filename}" scale="0.1 0.1 0.1" />
        </geometry>
        <material name="grey">
          <color rgba="0.5 0.5 0.5 1.0" />
        </material>
      </visual>

      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <cylinder radius="0.05" length="0.08" />
        </geometry>
      </collision>

      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="0.3" />
        <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01" />
      </inertial>
    </link>

    <joint name="${prefix}_lidar_joint" type="fixed">
      <parent link="base_link" />
      <child link="${prefix}_lidar_link" />
      <origin xyz="${x_offset*xy_reflect} ${y_offset*xy_reflect} 0.2" rpy="0 0 0" />
    </joint>
  </xacro:macro>
  <xacro:lidar prefix="front" xy_reflect="1" x_offset="0.38" y_offset="0.25" filename="lidar.stl" />
  <xacro:lidar prefix="back" xy_reflect="-1" x_offset="0.38" y_offset="0.25" filename="lidar.stl" />

  <link name="front_caster">
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <sphere radius="${wheel_radius - 0.005}" />
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0" />
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01" />
    </inertial>
  </link>

  <link name="rear_caster">
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <sphere radius="${wheel_radius - 0.005}" />
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0" />
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01" />
    </inertial>
  </link>


  <joint name="front_caster_joint" type="fixed">
    <parent link="base_link" />
    <child link="front_caster" />
    <origin xyz="0.3 0 ${wheel_radius - 0.005}" rpy="0 0 0" />
  </joint>

  <joint name="rear_caster_joint" type="fixed">
    <parent link="base_link" />
    <child link="rear_caster" />
    <origin xyz="-0.3 0 ${wheel_radius - 0.005}" rpy="0 0 0" />
  </joint>

  <!-- control simulation gazebo -->

  <gazebo reference="base_link">
    <material>Gazebo/White</material>
  </gazebo>

  <gazebo reference="left_wheel_link">
    <material>Gazebo/Black</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>

  <gazebo reference="right_wheel_link">
    <material>Gazebo/Black</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>

  <gazebo reference="front_caster">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
    <material>Gazebo/Grey</material>
  </gazebo>

  <gazebo reference="rear_caster">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
    <material>Gazebo/Grey</material>
  </gazebo>
  <gazebo>
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>

      <wheel_separation>${wheel_ygap * 2}</wheel_separation>
      <wheel_radius>${wheel_radius}</wheel_radius>
      <max_linear_acceleration>1.0</max_linear_acceleration>
      <max_angular_acceleration>1.0</max_angular_acceleration>
      <max_linear_velocity>1.5</max_linear_velocity>
      <max_angular_velocity>0.5</max_angular_velocity>

      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
      <odom_publisher_frequency>30</odom_publisher_frequency>
    </plugin>

    <plugin filename="gz-sim-joint-state-publisher-system"
      name="gz::sim::systems::JointStatePublisher">
      <topic>joint_states</topic>
      <joint_name>left_wheel_joint</joint_name>
      <joint_name>right_wheel_joint</joint_name>
    </plugin>
  </gazebo>

  <gazebo reference="front_lidar_link">
    <sensor name="front_lidar_sensor" type="gpu_lidar">
      <topic>/lidar_front</topic>
      <gz_frame_id>front_lidar_link</gz_frame_id>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
          <vertical>
            <samples>16</samples>
            <resolution>1</resolution>
            <min_angle>-0.2618</min_angle>
            <max_angle>0.2618</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.2</min>
          <max>30.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
      <always_on>1</always_on>
      <visualize>true</visualize>
    </sensor>
  </gazebo>
  <gazebo reference="back_lidar_link">
    <sensor name="back_lidar_sensor" type="gpu_lidar">
      <topic>/lidar_back</topic>
      <gz_frame_id>back_lidar_link</gz_frame_id>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
          <vertical>
            <samples>16</samples>
            <resolution>1</resolution>
            <min_angle>-0.2618</min_angle>
            <max_angle>0.2618</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.2</min>
          <max>30.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
      <always_on>1</always_on>
      <visualize>true</visualize>
    </sensor>
  </gazebo>
  <gazebo>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
  </gazebo>
</robot>